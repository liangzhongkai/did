{
  "@context": [
    "https://www.w3.org/2018/credentials/v1",
    "https://schema.iden3.io/core/jsonld/claim-vocab.json"
  ],
  "id": "BalanceCredential",
  "type": "JsonSchema",
  "schema": {
    "type": "object",
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "required": ["threshold", "zkCircuit"],
    "properties": {
      "threshold": {
        "type": "integer",
        "description": "Public balance threshold the holder must exceed"
      },
      "zkCircuit": {
        "type": "string",
        "description": "Associated Circom circuit name"
      },
      "verificationKeyHash": {
        "type": "string",
        "description": "Hash of Groth16 verification key for circuit binding"
      }
    }
  }
}
